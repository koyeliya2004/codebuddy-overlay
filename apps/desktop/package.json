{
  "name": "codebuddy-overlay",
  "version": "1.0.0",
  "description": "AI floating coding assistant powered by Groq",
  "author": "Koyeliya Ghosh",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && vite build && electron-builder --win --x64",
    "electron": "electron .",
    "vite": "vite"
  },
  "build": {
    "appId": "com.koyeliya.codebuddy",
    "productName": "CodeBuddy",
    "copyright": "Koyeliya Ghosh 2026",
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeBuddy",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  }
}
